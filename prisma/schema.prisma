generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String     @id @default(cuid())
  name      String
  joinCode  String     @unique
  createdAt DateTime   @default(now())
  users     User[]
  deliveries Delivery[]
  suppliers  Supplier[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  password     String?
  name         String?
  role         Role           @default(EMPLOYEE)
  status       UserStatus     @default(PENDING)
  companyId    String
  createdAt    DateTime       @default(now())
  company      Company        @relation(fields: [companyId], references: [id])
  messages     Message[]
  orderRequests OrderRequest[]
  notifications        Notification[]
  notificationSetting  NotificationSetting?
}

model Delivery {
  id            String         @id @default(cuid())
  productName   String
  quantity      Int
  deliveryDate  DateTime
  status        DeliveryStatus @default(PENDING)
  sourceType    SourceType
  sourceUrl     String?
  companyId     String
  supplierName  String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company        @relation(fields: [companyId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  chatRoom  String
  fileName  String?
  fileUrl   String?
  createdAt DateTime @default(now())
  sender    User     @relation(fields: [senderId], references: [id])
}

model OrderRequest {
  id           String        @id @default(cuid())
  productName  String
  quantity     Int?
  neededBy     DateTime?
  details      String?
  requesterId  String
  status       OrderStatus   @default(PENDING)
  adminComment String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  requester    User          @relation(fields: [requesterId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model NotificationSetting {
  id               String   @id @default(cuid())
  userId           String   @unique
  todayHour        Int      @default(7)
  tomorrowHour     Int      @default(18)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum DeliveryStatus {
  PENDING
  SHIPPED
  DELIVERED
  DELAYED
  CANCELLED
}

enum SourceType {
  FAX
  CSV
  IMAGE
  TEXT
  MANUAL
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  CHAT
  ORDER_STATUS
  DELIVERY_UPDATE
}
